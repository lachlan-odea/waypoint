rules_version = '2';

// Paste these into the Firestore Rules tab of the Firebase console
// (Build → Firestore Database → Rules). Any signed-in user — including the
// anonymous accounts the app creates on load — can read and write. The PIN
// gate inside the app is a soft check, not a security boundary; anyone with
// the deployed site URL can authenticate anonymously and edit the data, so
// don't store anything sensitive here. To lock down further, switch
// Anonymous Auth off and require Email/Google sign-in from the Firebase
// console.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
