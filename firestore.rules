rules_version = '2';

// Paste these into the Firestore Rules tab of the Firebase console
// (Build → Firestore Database → Rules). The designers collection is public
// read so the unauthenticated sign-up screen can show the "claim existing
// profile" picker; writes still require a signed-in user. All other
// collections require sign-in for both read and write.
service cloud.firestore {
  match /databases/{database}/documents {
    match /designers/{designerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /workspaces/{workspaceId} {
      allow read, write: if request.auth != null;
    }
    match /projects/{projectId} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null;
    }
  }
}
